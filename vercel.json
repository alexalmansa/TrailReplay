{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "app/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/app",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/app/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/app/tutorial",
      "destination": "/tutorial.html",
      "permanent": true
    },
    {
      "source": "/app/tutorial.html",
      "destination": "/tutorial.html",
      "permanent": true
    },
    {
      "source": "/app/gpx-download-guide",
      "destination": "/gpx-download-guide.html",
      "permanent": true
    },
    {
      "source": "/app/gpx-download-guide.html",
      "destination": "/gpx-download-guide.html",
      "permanent": true
    },
    {
      "source": "/app/privacy.html",
      "destination": "/privacy.html",
      "permanent": true
    },
    {
      "source": "/app/terms.html",
      "destination": "/terms.html",
      "permanent": true
    },
    {
      "source": "/app/acknowledgments.html",
      "destination": "/acknowledgments.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/app/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/app/media/(.*)",
      "destination": "/media/$1"
    },
    {
      "source": "/app/legal.css",
      "destination": "/legal.css"
    },
    {
      "source": "/app-v1",
      "destination": "/index.html"
    },
    {
      "source": "/app-v1/",
      "destination": "/index.html"
    },
    {
      "source": "/app-v1.html",
      "destination": "/index.html"
    },
    {
      "source": "/tutorial",
      "destination": "/tutorial.html"
    },
    {
      "source": "/tutorial/",
      "destination": "/tutorial.html"
    },
    {
      "source": "/tutorial.html",
      "destination": "/tutorial.html"
    },
    {
      "source": "/gpx-download-guide",
      "destination": "/gpx-download-guide.html"
    },
    {
      "source": "/gpx-download-guide/",
      "destination": "/gpx-download-guide.html"
    },
    {
      "source": "/gpx-download-guide.html",
      "destination": "/gpx-download-guide.html"
    },
    {
      "source": "/strava-callback",
      "destination": "/index.html"
    },
    {
      "source": "/strava-callback.html",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
} 
